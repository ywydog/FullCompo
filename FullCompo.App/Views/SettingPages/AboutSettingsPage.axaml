<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FullCompo.App.ViewModels"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="FullCompo.App.Views.SettingPages.AboutSettingsPage"
             x:DataType="vm:AppSettingsWindowViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12" Margin="32,24,32,24" HorizontalAlignment="Left">
            <TextBlock Text="关于"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,20" />

            <StackPanel Orientation="Horizontal" Spacing="20">
                <Border Width="80"
                        Height="80"
                        CornerRadius="{DynamicResource OverlayCornerRadius}"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Image Source="avares://FullCompo/Assets/logo.png"
                           Stretch="Uniform"
                           Margin="12" />
                </Border>

                <StackPanel VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="全面组件"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="{Binding Version}"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="一款简洁的桌面组件工具。"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
