<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FullCompo.App.Views.PanelSettingsDialog"
        Title="面板设置"
        Width="360"
        Height="400"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <TextBlock Text="面板设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="12">
                <TextBlock Text="面板名称" />
                <TextBox x:Name="NameBox" />

                <TextBlock Text="停靠位置" />
                <ComboBox x:Name="DockModeBox" HorizontalAlignment="Stretch" />

                <TextBlock Text="面板高度" />
                <NumericUpDown x:Name="PanelHeightBox" Minimum="40" Maximum="200" Increment="8" />

                <TextBlock Text="圆角半径" />
                <NumericUpDown x:Name="CornerRadiusBox" Minimum="0" Maximum="40" Increment="2" />

                <TextBlock Text="组件间距" />
                <NumericUpDown x:Name="SpacingBox" Minimum="0" Maximum="32" Increment="2" />

                <TextBlock Text="边距（左/上/右/下）" />
                <UniformGrid Columns="4">
                    <NumericUpDown x:Name="MarginLeftBox" Minimum="0" Maximum="200" Increment="4" />
                    <NumericUpDown x:Name="MarginTopBox" Minimum="0" Maximum="200" Increment="4" />
                    <NumericUpDown x:Name="MarginRightBox" Minimum="0" Maximum="200" Increment="4" />
                    <NumericUpDown x:Name="MarginBottomBox" Minimum="0" Maximum="200" Increment="4" />
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button x:Name="SaveButton" Content="保存" />
            <Button x:Name="CancelButton" Content="取消" />
        </StackPanel>
    </Grid>
</Window>
