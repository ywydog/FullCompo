<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FullCompo.App.Views.DesktopSurfaceWindow"
        Title="FullCompo"
        SystemDecorations="None"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        ShowActivated="False"
        WindowState="Normal"
        FontFamily="{DynamicResource ThemeFontFamily}">
    <Grid x:Name="RootGrid">
        <!-- Edit mode overlay -->
        <Canvas x:Name="EditOverlay" IsVisible="False" Background="#60000000" IsHitTestVisible="True" />
        <!-- Widgets canvas -->
        <Canvas x:Name="WidgetsCanvas" Background="Transparent" IsHitTestVisible="True" />
        <!-- Edit toolbar -->
        <Border x:Name="EditToolbar"
                IsVisible="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,24"
                Background="{DynamicResource ThemeSurfaceBrush}"
                BorderBrush="{DynamicResource ThemeDividerBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12,8"
                BoxShadow="0 4 16 0 #26000000">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="BtnReset" Content="↺ 重置视图" Foreground="{DynamicResource ThemeForegroundBrush}" />
                <Button x:Name="BtnAppearance" Content="🎨 外观" Foreground="{DynamicResource ThemeForegroundBrush}" />
                <Button x:Name="BtnAdd" Content="➕ 添加组件" Foreground="{DynamicResource ThemeForegroundBrush}" />
                <Button x:Name="BtnClear" Content="🗑 清空桌面" Foreground="{DynamicResource ThemeForegroundBrush}" />
                <Button x:Name="BtnUndo" Content="↩ 撤销" Foreground="{DynamicResource ThemeForegroundBrush}" />
                <Button x:Name="BtnRedo" Content="↪ 重做" Foreground="{DynamicResource ThemeForegroundBrush}" />
                <Button x:Name="BtnDone" Content="✓ 完成" Foreground="{DynamicResource ThemeForegroundBrush}" />
            </StackPanel>
        </Border>
        <!-- Side panel for size library / function selection -->
        <Border x:Name="SidePanel"
                IsVisible="False"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="280"
                Background="{DynamicResource ThemeSurfaceBrush}"
                BorderBrush="{DynamicResource ThemeDividerBrush}"
                BorderThickness="1,0,0,0"
                BoxShadow="-4 0 16 0 #1A000000">
            <Grid RowDefinitions="Auto,*">
                <TextBlock x:Name="SidePanelTitle"
                           Grid.Row="0"
                           Margin="16,12"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeForegroundBrush}" />
                <ScrollViewer Grid.Row="1">
                    <StackPanel x:Name="SidePanelContent" Margin="16,0,16,16" Spacing="8" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
