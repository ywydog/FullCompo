<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:animation="using:Avalonia.Animation"
        x:Class="FullCompo.App.Views.AppSettingsWindow"
        Title="设置"
        Width="800"
        Height="560"
        MinWidth="640"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid ColumnDefinitions="200,*">
        <Border Grid.Column="0"
                Background="#F5F5F5"
                BorderBrush="#22000000"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="设置"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="20,20,20,12"
                           Foreground="#1A1A1A" />
                <ListBox x:Name="NavList"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8,0,8,12">
                    <ListBoxItem Content="常规" />
                    <ListBoxItem Content="外观" />
                    <ListBoxItem Content="天气" />
                    <ListBoxItem Content="关于" />
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="*,Auto">
            <Border Grid.Row="0" Background="White">
                <TransitioningContentControl x:Name="ContentHost" Padding="24">
                    <TransitioningContentControl.Transition>
                        <animation:PageSlide Duration="0:0:0.22" SlideAxis="Horizontal" />
                    </TransitioningContentControl.Transition>
                </TransitioningContentControl>
            </Border>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="24,16,24,24">
                <Button x:Name="SaveButton" Content="保存" />
                <Button x:Name="CancelButton" Content="取消" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
