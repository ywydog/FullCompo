<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        x:Class="FullCompo.App.Views.AppSettingsWindow"
        Title="应用设置"
        Width="900"
        Height="640"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="Full"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
    <Grid RowDefinitions="40,*">
        <Border Grid.Row="0"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                WindowDecorationProperties.ElementRole="TitleBar">
            <DockPanel Margin="12,0">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Spacing="10">
                    <Image Source="avares://FullCompo.App/Assets/logo.png"
                           Width="18"
                           Height="18"
                           VerticalAlignment="Center" />
                    <TextBlock Text="应用设置"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="12"
                            Margin="0,0,120,0">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding Version}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ui:NavigationView Grid.Row="1"
                           x:Name="Nav"
                           PaneDisplayMode="Left"
                             IsBackButtonVisible="Collapsed"
                           IsPaneToggleButtonVisible="False"
                           IsSettingsVisible="False"
                           OpenPaneLength="220"
                           Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                           SelectionChanged="Nav_SelectionChanged">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Tag="General" Content="常规">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="Appearance" Content="外观">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Palette" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="Weather" Content="天气">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Cloud" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="About" Content="关于">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Info" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <Grid RowDefinitions="*,Auto">
                <ui:Frame Grid.Row="0" x:Name="ContentFrame" />
                <Border Grid.Row="1"
                        Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="24,16">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8">
                        <Button Content="保存"
                                Command="{Binding SaveCommand}" />
                        <Button Content="取消"
                                Command="{Binding CancelCommand}" />
                    </StackPanel>
                </Border>
            </Grid>
        </ui:NavigationView>
    </Grid>
</Window>
