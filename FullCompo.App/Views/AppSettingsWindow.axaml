<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FullCompo.App.Views.AppSettingsWindow"
        Title="FullCompo 设置"
        Width="900"
        Height="640"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        CanResize="False"
        FontFamily="{DynamicResource ThemeFontFamily}">
    <Grid ColumnDefinitions="220,*">
        <!-- 左侧导航栏 -->
        <Border Grid.Column="0"
                Background="{DynamicResource ThemeSidebarBrush}"
                Padding="16,20">
            <StackPanel Spacing="4">
                <TextBlock Text="设置"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeForegroundBrush}"
                           Margin="0,0,0,20" />

                <ListBox x:Name="NavList"
                         SelectionMode="Single"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0">
                    <ListBoxItem x:Name="NavGeneral" Content="常规" Padding="8,6" />
                    <ListBoxItem x:Name="NavAppearance" Content="外观" Padding="8,6" />
                    <ListBoxItem x:Name="NavPanel" Content="面板" Padding="8,6" />
                    <ListBoxItem x:Name="NavWeather" Content="天气" Padding="8,6" />
                    <ListBoxItem x:Name="NavAbout" Content="关于" Padding="8,6" />
                </ListBox>
            </StackPanel>
        </Border>

        <!-- 右侧内容区 -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto" Background="{DynamicResource ThemeSurfaceBrush}">

            <!-- 常规 -->
            <ScrollViewer x:Name="PageGeneral" Grid.Row="0" Margin="24,20,24,0">
                <StackPanel Spacing="16">
                    <TextBlock Text="常规" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ThemeForegroundBrush}" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="开机自启" Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="14" />
                        <ToggleSwitch x:Name="StartupToggle" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="显示托盘图标" Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="14" />
                        <ToggleSwitch x:Name="TrayToggle" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 外观 -->
            <ScrollViewer x:Name="PageAppearance" Grid.Row="0" Margin="24,20,24,0" IsVisible="False">
                <StackPanel Spacing="16">
                    <TextBlock Text="外观" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ThemeForegroundBrush}" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="主题" Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="14" />
                        <ComboBox x:Name="ThemeBox" Width="240" HorizontalAlignment="Left" />
                    </StackPanel>

                    <Border x:Name="ThemePreviewSettings"
                            Width="240"
                            Height="80"
                            CornerRadius="12"
                            BorderThickness="1"
                            Margin="0,4,0,0">
                        <TextBlock x:Name="PreviewTextBlockSettings"
                                   Text="主题预览"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 面板 -->
            <ScrollViewer x:Name="PagePanel" Grid.Row="0" Margin="24,20,24,0" IsVisible="False">
                <StackPanel Spacing="16">
                    <TextBlock Text="面板" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ThemeForegroundBrush}" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="停靠位置" Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="14" />
                        <TextBlock Text="选择组件面板在屏幕上的默认停靠位置" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="12" />
                        <ComboBox x:Name="DockPositionBox" Width="240" HorizontalAlignment="Left">
                            <ComboBoxItem Content="自由定位" />
                            <ComboBoxItem Content="屏幕顶部居中" />
                            <ComboBoxItem Content="屏幕左上角" />
                            <ComboBoxItem Content="屏幕右上角" />
                            <ComboBoxItem Content="屏幕底部居中" />
                            <ComboBoxItem Content="屏幕左下角" />
                            <ComboBoxItem Content="屏幕右下角" />
                            <ComboBoxItem Content="屏幕左侧" />
                            <ComboBoxItem Content="屏幕右侧" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="穿透点击（运行时鼠标可穿透面板）" Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="14" />
                        <ToggleSwitch x:Name="ClickThroughToggle" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 天气 -->
            <ScrollViewer x:Name="PageWeather" Grid.Row="0" Margin="24,20,24,0" IsVisible="False">
                <StackPanel Spacing="16">
                    <TextBlock Text="天气" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ThemeForegroundBrush}" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="启用天气" Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="14" />
                        <ToggleSwitch x:Name="WeatherEnabledToggle" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="当前城市" Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="14" />
                        <TextBlock x:Name="WeatherCityText" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="13" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox x:Name="WeatherCitySearchText" Grid.Column="0" Watermark="搜索城市或省份…" />
                            <Button x:Name="WeatherSearchButton" Grid.Column="1" Content="搜索" Margin="8,0,0,0" />
                        </Grid>
                        <ListBox x:Name="WeatherCityResults" MaxHeight="160" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="不使用 TLS 获取天气" Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="14" />
                        <TextBlock Text="不建议，但可能改善兼容性较差的网络环境。" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="12" />
                        <ToggleSwitch x:Name="WeatherNoTLSToggle" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 关于 -->
            <ScrollViewer x:Name="PageAbout" Grid.Row="0" Margin="24,20,24,0" IsVisible="False">
                <StackPanel Spacing="12">
                    <TextBlock Text="关于" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ThemeForegroundBrush}" />

                    <Image Width="48"
                           Height="48"
                           Source="avares://FullCompo.App/Assets/logo.ico"
                           HorizontalAlignment="Left" />

                    <TextBlock Text="FullCompo" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ThemeForegroundBrush}" />
                    <TextBlock Text="版本 1.0.0" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="13" />
                    <TextBlock Text="在桌面上搭建你的个性化信息面板。"
                               Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="13" TextWrapping="Wrap" />
                    <TextBlock Text="https://github.com/fengjian868/FullCompo"
                               Foreground="{DynamicResource ThemeAccentBrush}" FontSize="13" />
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="1"
                    Background="{DynamicResource ThemeSidebarBrush}"
                    BorderBrush="{DynamicResource ThemeDividerBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="24,12"
                    HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="12">
                    <Button x:Name="CancelButton"
                            Content="取消"
                            Padding="16,6"
                            Background="{DynamicResource ThemeSurfaceBrush}"
                            Foreground="{DynamicResource ThemeForegroundBrush}" />
                    <Button x:Name="SaveButton"
                            Content="保存"
                            Padding="16,6"
                            Background="{DynamicResource ThemeAccentBrush}"
                            Foreground="White" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
