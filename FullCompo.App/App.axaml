<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="FullCompo.App.App">

    <Application.Styles>
        <sty:FluentAvaloniaTheme />

        <!-- Global default font; overridden by ThemeFontFamily at runtime -->
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
        </Style>
        <Style Selector="TemplatedControl">
            <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <!-- 基础色 -->
        <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#B31E1E1E" />
        <SolidColorBrush x:Key="ThemeForegroundBrush" Color="White" />
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FF4A90E2" />
        <SolidColorBrush x:Key="ThemeBorderBrush" Color="#55FFFFFF" />

        <!-- 语义色 -->
        <SolidColorBrush x:Key="ThemeSurfaceBrush" Color="#CC2D2D2D" />
        <SolidColorBrush x:Key="ThemeSidebarBrush" Color="#CC252525" />
        <SolidColorBrush x:Key="ThemeSecondaryForegroundBrush" Color="#FFAAAAAA" />
        <SolidColorBrush x:Key="ThemeDisabledForegroundBrush" Color="#FF666666" />
        <SolidColorBrush x:Key="ThemeDividerBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="ThemeHoverBrush" Color="#1AFFFFFF" />
        <SolidColorBrush x:Key="ThemeSelectionBrush" Color="#334A90E2" />
        <SolidColorBrush x:Key="ThemeErrorBrush" Color="#FFFF4444" />
        <SolidColorBrush x:Key="ThemeSuccessBrush" Color="#FF44CC88" />

        <!-- 数值 -->
        <x:Double x:Key="ThemeBorderThickness">1</x:Double>
        <CornerRadius x:Key="ThemeCornerRadius">16</CornerRadius>
        <x:Double x:Key="ThemeFontSizeScale">1.0</x:Double>
        <x:Double x:Key="ThemeOpacity">0.92</x:Double>
        <x:Boolean x:Key="ThemeUseAcrylic">true</x:Boolean>
        <FontFamily x:Key="ThemeFontFamily">HarmonyOS Sans, HarmonyOS Sans SC, Microsoft YaHei UI, Microsoft YaHei, PingFang SC, Segoe UI, sans-serif</FontFamily>
    </Application.Resources>
</Application>
